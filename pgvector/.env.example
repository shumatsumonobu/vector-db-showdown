# Voyage AI — テキストをベクトルに変換するAPI
# 1. https://dash.voyageai.com/ でアカウント作成
# 2. ダッシュボードからAPIキーを発行
# 3. 下の値を自分のキーに置き換える
VOYAGE_API_KEY=your-voyage-api-key-here

# PostgreSQL接続情報
# Dockerで起動する場合: docker run -d --name pgvector -p 5433:5432 -e POSTGRES_PASSWORD=postgres pgvector/pgvector:pg17
# ポート番号(5433)は他のPostgreSQLと被らないように変更可能
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
